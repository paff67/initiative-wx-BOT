# Copy to ${HERMES_HOME}/linjiang-llm.env on the VPS.
# chmod 600 this file because it can contain API keys.

# State LLM: maintains linjiang-internal-state.json.
WX_LINJIANG_STATE_BASE_URL=http://127.0.0.1:8788/v1
WX_LINJIANG_STATE_API_KEY=REPLACE_ME
WX_LINJIANG_STATE_MODEL=gpt-5.4
WX_LINJIANG_STATE_TEMPERATURE=0.8
WX_LINJIANG_STATE_TOP_P=0.9
WX_LINJIANG_STATE_MAX_TOKENS=5000
WX_LINJIANG_STATE_PRESENCE_PENALTY=0.4
WX_LINJIANG_STATE_FREQUENCY_PENALTY=0.5
WX_LINJIANG_STATE_REASONING_EFFORT=high
WX_LINJIANG_STATE_EXTRA_BODY=
WX_LINJIANG_STATE_PROXY_BYPASS=
WX_LINJIANG_STATE_PROMPT_PATH=${HERMES_HOME}/wx-linjiang-state-prompt.md
WX_LINJIANG_INTERNAL_STATE_PATH=${HERMES_HOME}/linjiang-internal-state.json
WX_LINJIANG_STATE_RECENT_ROUNDS=4
WX_LINJIANG_STATE_TIMEOUT=180

# Decision LLM: chooses silent / send / hesitate.
WX_PROACTIVE_DECISION_BASE_URL=http://127.0.0.1:8788/v1
WX_PROACTIVE_DECISION_API_KEY=REPLACE_ME
WX_PROACTIVE_DECISION_MODEL=gpt-5.4
WX_PROACTIVE_DECISION_TEMPERATURE=0.1
WX_PROACTIVE_DECISION_TOP_P=0.4
WX_PROACTIVE_DECISION_MAX_TOKENS=4000
WX_PROACTIVE_DECISION_PRESENCE_PENALTY=0
WX_PROACTIVE_DECISION_FREQUENCY_PENALTY=0
WX_PROACTIVE_DECISION_REASONING_EFFORT=
WX_PROACTIVE_DECISION_EXTRA_BODY=
WX_PROACTIVE_DECISION_PROXY_BYPASS=
WX_PROACTIVE_DECISION_PROMPT_PATH=${HERMES_HOME}/wx-proactive-decision-prompt.md
WX_PROACTIVE_RECENT_ROUNDS=4
WX_PROACTIVE_DECISION_TIMEOUT=180
WX_PROACTIVE_DAILY_MAX=3
WX_PROACTIVE_MIN_GAP_MINUTES=180
WX_PROACTIVE_MIN_SEND_CONFIDENCE=0.55

TZ=Asia/Shanghai
WX_PROACTIVE_TZ=Asia/Shanghai
WX_LINJIANG_STATE_TZ=Asia/Shanghai
WX_GREETING_TZ=Asia/Shanghai
